wire y0, y1, y2, y3;

demux1to4_dataflow uut(y0, y1, y2, y3, d, s0, s1);

initial begin
    $monitor("[Dataflow] t=%0t s1s0=%b%b d=%b | y=%b%b%b%b", $time, s1, s0, d, y3, y2, y1, y0);
    d=1;
    s1=0; s0=0; #10;
    s1=0; s0=1; #10;
    s1=1; s0=0; #10;
    s1=1; s0=1; #10;
    $finish;
end
endmodule


// ============================================
// 3. Behavioral Modeling (1:4 DEMUX)
// ============================================
module demux1to4_behavioral(y0, y1, y2, y3, d, s0, s1);
output reg y0, y1, y2, y3;
input d, s0, s1;

always @(*) begin
    {y3, y2, y1, y0} = 4'b0000;
    case({s1, s0})
        2'b00: y0 = d;
        2'b01: y1 = d;
        2'b10: y2 = d;
        2'b11: y3 = d;
    endcase
end

endmodule

// Testbench
