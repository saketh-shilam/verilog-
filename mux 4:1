    s1=0;s0=0; #10;
    s1=0;s0=1; #10;
    s1=1;s0=0; #10;
    s1=1;s0=1; #10;
    $finish;
end
endmodule


// ============================================
// 4. Switch-Level (Simplified)
// ============================================
module mux4to1_switch(y, i0, i1, i2, i3, s0, s1);
output y;
input i0, i1, i2, i3, s0, s1;

assign y = (~s1 & ~s0 & i0) |
           (~s1 &  s0 & i1) |
           ( s1 & ~s0 & i2) |
           ( s1 &  s0 & i3);

endmodule

// Testbench
module tb_mux4to1_switch;
reg i0,i1,i2,i3,s0,s1;
wire y;

