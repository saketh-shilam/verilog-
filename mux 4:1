initial begin
    $monitor("[Switch-like] t=%0t s1s0=%b%b | y=%b",$time,s1,s0,y);
    i0=0;i1=1;i2=0;i3=1;
    s1=0;s0=0; #10;
    s1=0;s0=1; #10;
    s1=1;s0=0; #10;
    s1=1;s0=1; #10;
    $finish;
end
endmodule

