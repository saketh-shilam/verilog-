initial begin
    $monitor("[Behavioral] t=%0t s1s0=%b%b d=%b | y=%b%b%b%b", $time, s1, s0, d, y3, y2, y1, y0);
    d=1;
    s1=0; s0=0; #10;
    s1=0; s0=1; #10;
    s1=1; s0=0; #10;
    s1=1; s0=1; #10;
    $finish;
end
endmodule


// ============================================
// 4. Switch-Level (Simplified DEMUX)
// ============================================
module demux1to4_switch(y0, y1, y2, y3, d, s0, s1);
output y0, y1, y2, y3;
input d, s0, s1;

assign y0 = d & ~s1 & ~s0;
assign y1 = d & ~s1 &  s0;
assign y2 = d &  s1 & ~s0;
assign y3 = d &  s1 &  s0;

endmodule

// Testbench
